# --- Substreams credentials ------------------------------------------------
# Set one of SUBSTREAMS_API_KEY or SUBSTREAMS_TOKEN. With an API key, the
# server exchanges it for a short-lived JWT at SUBSTREAMS_AUTH_URL and sends
# `Authorization: Bearer <jwt>`. With a raw token, it is sent as-is. Setting
# SUBSTREAMS_AUTH_URL=none disables the exchange and sends the API key in the
# configured header instead (graph-node style).
SUBSTREAMS_API_KEY=
SUBSTREAMS_TOKEN=
SUBSTREAMS_AUTH_URL=https://auth.pinax.network/v1/auth/issue
SUBSTREAMS_API_KEY_HEADER=X-Api-Key

# --- Substreams runtime flags (apply to every configured stream) -----------
SUBSTREAMS_PRODUCTION_MODE=false
SUBSTREAMS_FINAL_BLOCKS_ONLY=false
SUBSTREAMS_PLAINTEXT=false
SUBSTREAMS_INSECURE=false

# --- WebSocket server ------------------------------------------------------
SUBSTREAMS_WEBSOCKET_STREAMS=./streams.toml
# Inline streams TOML — wins over SUBSTREAMS_WEBSOCKET_STREAMS when set.
# Required for Railway / Fly / Heroku deploys (no writable filesystem for the
# file). Paste the full `[[streams]]` content as the value.
SUBSTREAMS_WEBSOCKET_STREAMS_TOML=
SUBSTREAMS_WEBSOCKET_LISTEN=0.0.0.0:8080
SUBSTREAMS_WEBSOCKET_WS_PATH=/ws
SUBSTREAMS_WEBSOCKET_STREAM_PATH=/stream
SUBSTREAMS_WEBSOCKET_HEALTH_PATH=/healthz
# Prometheus metrics endpoint. Set to empty to disable.
SUBSTREAMS_WEBSOCKET_METRICS_PATH=/metrics
SUBSTREAMS_WEBSOCKET_HEARTBEAT_INTERVAL_SECS=180
SUBSTREAMS_WEBSOCKET_HEARTBEAT_TIMEOUT_SECS=600
SUBSTREAMS_WEBSOCKET_MAX_CLIENTS=1024
SUBSTREAMS_WEBSOCKET_CLIENT_BUFFER_SIZE=1024
# Force-close a WebSocket client after this many consecutive `try_send`
# drops on a saturated outbound buffer. Relieves bus-wide backpressure
# when one slow consumer can't keep up. 0 disables (per-frame drops only,
# never force-close). Default 100.
SUBSTREAMS_WEBSOCKET_SLOW_CLIENT_DROP_LIMIT=100
SUBSTREAMS_WEBSOCKET_SHUTDOWN_DRAIN_SECS=10
SUBSTREAMS_WEBSOCKET_CURSORS_DIR=./cursors

# --- Replay log ------------------------------------------------------------
# Per-spkg JSONL log used to replay missed blocks to reconnecting clients
# via `?from_timestamp=<n>` (Unix epoch seconds or UTC `YYYY-MM-DD HH:MM:SS`).
# Retention is a time window in seconds: every block whose timestamp_seconds
# is within [newest_seen - N, newest_seen] is kept. Default 600s (10 min);
# 0 disables.
SUBSTREAMS_WEBSOCKET_REPLAY_SECONDS=600
SUBSTREAMS_WEBSOCKET_REPLAY_DIR=./replay

# --- Event filters ---------------------------------------------------------
# Bounds on client-supplied event filters (see docs/filters.md).
SUBSTREAMS_WEBSOCKET_MAX_FILTER_FIELDS=16
SUBSTREAMS_WEBSOCKET_MAX_FILTER_VALUES=64
