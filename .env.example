SUBSTREAMS_ENDPOINT=https://solana.substreams.pinax.network:443
SUBSTREAMS_NETWORK=
SUBSTREAMS_START_BLOCK=
SUBSTREAMS_STOP_BLOCK=0
SUBSTREAMS_PARAMS=
SUBSTREAMS_PRODUCTION_MODE=false
SUBSTREAMS_FINAL_BLOCKS_ONLY=false
# Set one of the two. When SUBSTREAMS_API_KEY is set the server exchanges it
# for a short-lived JWT at SUBSTREAMS_AUTH_URL and sends it as
# `Authorization: Bearer <jwt>`. When SUBSTREAMS_TOKEN is set it is sent as-is.
SUBSTREAMS_API_KEY=
SUBSTREAMS_TOKEN=
SUBSTREAMS_AUTH_URL=https://auth.pinax.network/v1/auth/issue

SUBSTREAMS_WEBSOCKET_CONFIG=config.example.toml
SUBSTREAMS_WEBSOCKET_LISTEN=127.0.0.1:8080
SUBSTREAMS_WEBSOCKET_WS_PATH=/ws
SUBSTREAMS_WEBSOCKET_HEALTH_PATH=/healthz
SUBSTREAMS_WEBSOCKET_HEARTBEAT_INTERVAL_SECS=180
SUBSTREAMS_WEBSOCKET_HEARTBEAT_TIMEOUT_SECS=600
SUBSTREAMS_WEBSOCKET_MAX_CLIENTS=1024
SUBSTREAMS_WEBSOCKET_CLIENT_BUFFER_SIZE=1024
